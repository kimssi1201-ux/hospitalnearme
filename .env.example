# Cloudflare Pages environment variables
# 실제 키는 GitHub에 올리지 말고 Cloudflare Pages > Settings > Environment variables에만 등록하세요.

# Recipe API
RECIPE_API_KEY=your_recipe_api_key_here

# Seoul Open Data cultural event API
SEOUL_OPEN_API_KEY=your_seoul_open_api_key_here

# Seoul public parking API
SEOUL_PARKING_API_KEY=your_seoul_parking_api_key_here

# OpenAI API for generated festival guide text
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2

# MyRealTrip API
# 사용자가 제공한 실제 키는 이 파일에 쓰지 말고 Cloudflare 환경변수에 등록하세요.
MYREALTRIP_API_KEY=your_myrealtrip_api_key_here

# 마이리얼트립 숙소 검색 API endpoint
# 전체 URL 또는 /v1/products/accommodation/search 경로만 넣어도 됩니다.
MYREALTRIP_API_ENDPOINT=/v1/products/accommodation/search
